---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | AI Daily Digest</title>
</head>
<body class="min-h-screen">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold text-gray-900">AI Daily Digest</a>
      <nav class="flex gap-4">
        <a href="/" class="text-gray-600 hover:text-gray-900">首页</a>
        <a href="/archive" class="text-gray-600 hover:text-gray-900">归档</a>
      </nav>
    </div>
  </header>
  
  <main class="max-w-6xl mx-auto px-4 py-8">
    <slot />
  </main>
  
  <footer class="border-t border-gray-200 mt-16">
    <div class="max-w-6xl mx-auto px-4 py-6 text-center text-sm text-gray-500">
      AI Daily Digest &copy; {new Date().getFullYear()}
    </div>
  </footer>
</body>
</html>
