---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const digests = await getCollection('digest');
  return digests.map(d => ({
    params: { slug: d.slug },
    props: { digest: d },
  }));
}

const { digest } = Astro.props;
const { Content } = await render(digest);
---

<Layout title={digest.data.title}>
  <article class="max-w-4xl mx-auto">
    <header class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-blue-600 transition-colors">首页</a>
        <span class="text-gray-300">/</span>
        <a href={`/archive/${new Date(digest.data.date).getFullYear()}`} class="hover:text-blue-600 transition-colors">
          {new Date(digest.data.date).getFullYear()}年
        </a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-600">{digest.data.date.toLocaleDateString('zh-CN')}</span>
      </nav>
      
      <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight">{digest.data.title}</h1>
      
      {digest.data.summary && (
        <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-lg mb-6">
          <p class="text-gray-700 leading-relaxed">{digest.data.summary}</p>
        </div>
      )}
      
      {digest.data.tags && digest.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {digest.data.tags.map(tag => (
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full font-medium">{tag}</span>
          ))}
        </div>
      )}
    </header>
    
    <div class="digest-content bg-white rounded-xl shadow-sm border border-gray-200 p-6 md:p-8">
      <Content />
    </div>
    
    <footer class="mt-8 pt-6 border-t border-gray-200 flex items-center justify-between">
      <a href="/" class="text-blue-600 hover:text-blue-800 transition-colors font-medium">← 返回首页</a>
      <a href={`/archive/${new Date(digest.data.date).getFullYear()}`} class="text-gray-600 hover:text-gray-800 transition-colors text-sm">
        {new Date(digest.data.date).getFullYear()}年归档 →
      </a>
    </footer>
  </article>
</Layout>

<style>
.digest-content h2 {
  margin-top: 2.5rem;
  padding-bottom: 0.5rem;
}

.digest-content h2:first-child {
  margin-top: 0;
}

.digest-content > hr {
  margin: 2.5rem 0;
}

.digest-content blockquote {
  margin: 1.25rem 0;
}
</style>
