---
import Layout from '../../../layouts/Layout.astro';
import YearNav from '../../../components/YearNav.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const digests = await getCollection('digest');
  const paths: { params: { year: string; month: string }; props: any }[] = [];
  
  digests.forEach(d => {
    const date = new Date(d.data.date);
    const year = String(date.getFullYear());
    const month = String(date.getMonth() + 1).padStart(2, '0');
    
    if (!paths.find(p => p.params.year === year && p.params.month === month)) {
      paths.push({
        params: { year, month },
        props: { year: parseInt(year), month: parseInt(month), digests },
      });
    }
  });
  
  return paths;
}

const { year, month, digests } = Astro.props;
const allDigests = await getCollection('digest');
const years = [...new Set(allDigests.map(d => new Date(d.data.date).getFullYear()))].sort((a, b) => b - a);

const monthDigests = digests
  .filter((d: any) => {
    const date = new Date(d.data.date);
    return date.getFullYear() === year && date.getMonth() + 1 === month;
  })
  .sort((a: any, b: any) => +new Date(b.data.date) - +new Date(a.data.date));

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', 
                   '七月', '八月', '九月', '十月', '十一月', '十二月'];
---

<Layout title={`${year}年${monthNames[month - 1]}归档`}>
  <div class="space-y-6">
    <nav class="flex items-center gap-2 text-sm text-gray-500">
      <a href="/" class="hover:text-blue-600 transition-colors">首页</a>
      <span class="text-gray-300">/</span>
      <a href={`/archive/${year}`} class="hover:text-blue-600 transition-colors">{year}年</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-600">{monthNames[month - 1]}</span>
    </nav>
    
    <header>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{year}年{monthNames[month - 1]}</h1>
      <YearNav years={years} activeYear={year} />
    </header>
    
    <div class="space-y-4">
      {monthDigests.length === 0 ? (
        <div class="text-center py-12 text-gray-500">
          <p>暂无内容</p>
        </div>
      ) : (
        monthDigests.map((d: any) => (
          <article class="digest-card">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h2 class="text-lg font-semibold text-gray-900">
                  <a href={`/digest/${d.slug}`} class="hover:text-blue-600 transition-colors line-clamp-2">
                    {d.data.title}
                  </a>
                </h2>
                <p class="text-gray-500 text-sm mt-1">{d.data.date.toLocaleDateString('zh-CN')}</p>
                {d.data.summary && (
                  <p class="text-gray-700 mt-2 line-clamp-2 leading-relaxed">{d.data.summary}</p>
                )}
              </div>
              {d.data.tags && d.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 flex-shrink-0">
                  {d.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded font-medium">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))
      )}
    </div>
  </div>
</Layout>
