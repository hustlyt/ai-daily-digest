---
import Layout from '../layouts/Layout.astro';
import YearNav from '../components/YearNav.astro';
import { getCollection } from 'astro:content';

const digests = await getCollection('digest');
const years = [...new Set(digests.map(d => new Date(d.data.date).getFullYear()))].sort((a, b) => b - a);
const latest = digests.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))[0];
---

<Layout title="首页">
  <div class="space-y-8">
    <section>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">AI Daily Digest</h1>
      <p class="text-gray-600">每日 AI 资讯汇总与解读</p>
    </section>

    {latest && (
      <section class="digest-card">
        <div class="text-sm text-blue-600 font-medium mb-2">最新日报</div>
        <h2 class="text-xl font-semibold mb-2">
          <a href={`/digest/${latest.slug}`} class="hover:text-blue-600">
            {latest.data.title}
          </a>
        </h2>
        <p class="text-gray-500 text-sm mb-3">{latest.data.date.toLocaleDateString('zh-CN')}</p>
        {latest.data.summary && (
          <p class="text-gray-700 line-clamp-3">{latest.data.summary}</p>
        )}
      </section>
    )}

    <section>
      <h2 class="text-lg font-semibold mb-4">按年份浏览</h2>
      <YearNav years={years} />
    </section>
  </div>
</Layout>
