---
import Layout from '../layouts/Layout.astro';
import YearNav from '../components/YearNav.astro';
import { getCollection } from 'astro:content';

const digests = await getCollection('digest');
const years = [...new Set(digests.map(d => new Date(d.data.date).getFullYear()))].sort((a, b) => b - a);
const latest = digests.sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))[0];
---

<Layout title="首页">
  <div class="space-y-8">
    <section class="text-center py-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-3">AI Daily Digest</h1>
      <p class="text-lg text-gray-600">每日 AI 资讯汇总与解读</p>
    </section>

    {latest && (
      <section>
        <div class="flex items-center gap-2 mb-4">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-green-600">最新日报</span>
        </div>
        <a href={`/digest/${latest.slug}`} class="block digest-card hover:shadow-md transition-shadow">
          <h2 class="text-xl font-semibold text-gray-900 mb-2 hover:text-blue-600 transition-colors">
            {latest.data.title}
          </h2>
          <p class="text-gray-500 text-sm mb-3">{latest.data.date.toLocaleDateString('zh-CN')}</p>
          {latest.data.summary && (
            <p class="text-gray-700 line-clamp-3 leading-relaxed">{latest.data.summary}</p>
          )}
        </a>
      </section>
    )}

    <section>
      <h2 class="text-lg font-semibold text-gray-900 mb-4">按年份浏览</h2>
      <YearNav years={years} />
    </section>
  </div>
</Layout>
