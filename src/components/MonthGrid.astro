---
import type { CollectionEntry } from 'astro:content';

interface Props {
  year: number;
  digests: CollectionEntry<'digest'>[];
}

const { year, digests } = Astro.props;

// Group by month
const byMonth = new Map<number, CollectionEntry<'digest'>[]>();
for (let i = 1; i <= 12; i++) {
  byMonth.set(i, []);
}

digests.forEach(d => {
  const date = new Date(d.data.date);
  if (date.getFullYear() === year) {
    const month = date.getMonth() + 1;
    byMonth.get(month)?.push(d);
  }
});

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', 
                   '七月', '八月', '九月', '十月', '十一月', '十二月'];
---

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
  {Array.from(byMonth.entries()).map(([month, items]) => (
    <a 
      href={items.length > 0 ? `/archive/${year}/${String(month).padStart(2, '0')}` : '#'}
      class={`p-4 rounded-lg border transition-all ${
        items.length > 0 
          ? 'bg-white border-gray-200 hover:border-blue-400 hover:shadow-sm' 
          : 'bg-gray-50 border-gray-100 opacity-50 cursor-default'
      }`}
    >
      <div class="text-lg font-semibold text-gray-900">{monthNames[month - 1]}</div>
      <div class="text-sm text-gray-500 mt-1">
        {items.length > 0 ? `${items.length} 篇日报` : '无数据'}
      </div>
    </a>
  ))}
</div>
